line level    source

   1          #include <REGX52.H>
   2          #include "Key.h"
   3          #include "Nixie.h"
   4          #include "Timer0.h"
   5          
   6          //定义引脚
   7          sbit LED=P2^0;
   8          sbit Motor=P1^0;
   9          
  10          
  11          unsigned char Count,Compare;
  12          unsigned char KeyNum,Speed;
  13          
  14          void main()
  15          {
  16   1              Timer0Init();                   //定时器0初始化
  17   1              while(1)
  18   1              {       
  19   2                      KeyNum=Key();
  20   2                      if(KeyNum==1)           //按键一进行电机速度切换
  21   2                      {
  22   3                              Speed++;
  23   3                              Speed%=4;
  24   3                      }
  25   2                      if(Speed==0) {Compare=0;}               //不同档位对应的比较值
  26   2                      if(Speed==1) {Compare=50;}
  27   2                      if(Speed==2) {Compare=75;}
  28   2                      if(Speed==3) {Compare=100;}
  29   2                      
  30   2                      Nixie(1,Speed);         //数码管显示当前电机的档位值
  31   2              }
  32   1      }
  33          
  34          void Timer0_Routine() interrupt 1
  35          {
  36   1              TL0 = 0xA4;             //设置定时初值    设置计数时间为100us
  37   1              TH0 = 0xFF;             //设置定时初值
  38   1              Count++;
  39   1              Count%=100;             //计数从0-100循环
  40   1              if(Count<Compare)       //判断计数值和比较值，以此来进行PWM调波进而控制电机转速
  41   1              {
  42   2                      Motor=1;        //电机启动
  43   2              }
  44   1              else
  45   1              {
  46   2                      Motor=0;        //电机停止
  47   2              }       
  48   1      }


