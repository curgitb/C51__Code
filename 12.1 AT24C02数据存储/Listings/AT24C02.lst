line level    source

   1          #include "I2C.h"
   2          
   3          /*AT24C02的固定地址为1010，可配置地址本开发板上为000
   4                  所以SLAVE ADDRESS+W为0xA0，SLAVE ADDRESS+R为0xA1
   5                  则定义AT24C02的写入地址为0xA0*/
   6          #define SlaveAddress 0xA0
   7          
   8          /**
   9           * @brief       AT24C02写入一个字节
  10           * @param       WordAddress 要写入的字地址
  11           * @param       Data 要写入的数据
  12           * @retval      无
  13           */void AT24C02_WriteByte(unsigned char WordAddress,Data)
  14          {
  15   1              I2C_Start();
  16   1              I2C_SendByte(SlaveAddress);
  17   1              I2C_ReceiveAck();
  18   1              I2C_SendByte(WordAddress);
  19   1              I2C_ReceiveAck();
  20   1              I2C_SendByte(Data);
  21   1              I2C_ReceiveAck();
  22   1              I2C_Stop();
  23   1      }
  24          
  25          /**
  26           * @brief       AT24C02读出一个字节
  27           * @param       WordAddress 要读出数据所在的字地址
  28           * @retval      读出的数据
  29           */
  30          unsigned char AT24C02_ReadByte(unsigned char WordAddress)
  31          {
  32   1              unsigned char Data;
  33   1              
  34   1              I2C_Start();
  35   1              I2C_SendByte(SlaveAddress);
  36   1              I2C_ReceiveAck();
  37   1              I2C_SendByte(WordAddress);
  38   1              I2C_ReceiveAck();
  39   1              I2C_Start();
  40   1              I2C_SendByte(SlaveAddress | 0x01);      
  41   1              I2C_ReceiveAck();
  42   1              Data=I2C_ReceiveByte();
  43   1              I2C_SendAck(1);
  44   1              I2C_Stop();
  45   1              
  46   1              return Data;
  47   1      }


