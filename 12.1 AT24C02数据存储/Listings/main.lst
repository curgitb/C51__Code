  33   3                              LCD_ShowString(2,1,"Write OK!");
  34   3                              Delay(1000);
  35   3                              LCD_ShowString(2,1,"         ");
  36   3                      }
  37   2                      if(KeyNum==4)   //按键4按下，从AT24C02中读出数据，E2PROM，掉电不丢失
  38   2                      {
  39   3                              Num=AT24C02_ReadByte(0);
  40   3                              Num|=AT24C02_ReadByte(1)<<8;
  41   3                              LCD_ShowNum(2,1,Num,5);                 
