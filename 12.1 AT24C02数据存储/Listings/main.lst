  15   1              while(1)
  16   1              {
  17   2                      KeyNum=Key();   //获取键码值
  18   2                      if(KeyNum==1)   //按键1按下，数据+1
  19   2                      {
  20   3                              Num++;
  21   3                              LCD_ShowNum(2,1,Num,5);
  22   3                      }
  23   2                      if(KeyNum==2)   //按键2按下，数据-1
  24   2                      {
