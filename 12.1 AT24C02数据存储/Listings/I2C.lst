  23           * @retval      无
  24           */
  25          void I2C_Stop(void)
  26          {
  27   1              I2C_SCL=0;
  28   1              I2C_SDA=0;
  29   1              I2C_SCL=1;      
  30   1              I2C_SDA=1;
  31   1      }
  32          
  33          /**
  34           * @brief       I2C发送一个字节
  35           * @param       Byte 要发送的这个字节数据
  36           * @retval      无
  37           */
  38          void I2C_SendByte(unsigned char Byte)
  39          {
  40   1              unsigned char i;
  41   1              
  42   1              for(i=0;i<8;i++)        //逐次将SDA上的数据发送出去
  43   1              {
  44   2                      I2C_SDA=Byte&(0x80>>i);
  45   2                      I2C_SCL=1;
  46   2                      I2C_SCL=0;
  47   2              }
  48   1              
  49   1      }
