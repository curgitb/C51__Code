  51          /**
  52           * @brief       I2C接收一个字节
  53           * @param       无
  54           * @retval      接收到的字节数据
C51 COMPILER V9.54   I2C                                                                   03/06/2026 22:36:38 PAGE 2   

  55           */
  56          unsigned char I2C_ReceiveByte(void)
  57          {
  58   1              unsigned char Byte=0x00,i;
  59   1              
  60   1              I2C_SDA=1;              //先将SDA上的数据释放
  61   1              for(i=0;i<8;i++)        //逐次将SDA上的数据读取进来
  62   1              {
  63   2                      if(I2C_SDA) {Byte |= (0x80>>i);}
  64   2                      I2C_SCL=1;
  65   2                      I2C_SCL=0;
  66   2              }
  67   1              
  68   1              return Byte;
  69   1      }
