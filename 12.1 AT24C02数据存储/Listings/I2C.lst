  71          /**
  72           * @brief       I2C发送应答
  73           * @param       AckBit I2C发送应答位，0为应答，1为非应答
  74           * @retval      无
  75           */
  76          void I2C_SendAck(unsigned char AckBit)
  77          {
  78   1              I2C_SDA=AckBit;
  79   1              I2C_SCL=1;
  80   1              I2C_SCL=0;
  81   1      }
  82          
  83          /**
  84           * @brief       I2C接收应答
  85           * @param       无
  86          * @retval       接收到的应答位，0为应答，1为非应答
  87           */
  88          unsigned char I2C_ReceiveAck(void)
  89          {
  90   1              unsigned char AckBit;
  91   1              
  92   1              I2C_SDA=1;              //先将SDA上的数据释放
  93   1              AckBit=I2C_SDA; 
  94   1              I2C_SCL=1;      
  95   1              I2C_SCL=0;
  96   1              
  97   1              return AckBit;
  98   1      }


