   6          
   7          /**
   8           * @brief       I2C开始
   9           * @param       无
  10           * @retval      无
  11           */
  12          void I2C_Start(void)
  13          {
  14   1              I2C_SDA=1;              //先将SDA拉高，再将SCL拉高，在SCL为高电平期间，SDA不能随意变动
  15   1              I2C_SCL=1;
  16   1              I2C_SDA=0;
  17   1              I2C_SCL=0;
  18   1      }
  19          
  20          /**
