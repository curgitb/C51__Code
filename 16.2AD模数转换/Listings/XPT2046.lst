line level    source

   1          #include <REGX52.H>
   2          
   3          //XPT2046引脚定义
   4          sbit XPT2046_DIN=P3^4;
   5          sbit XPT2046_CS=P3^5;
   6          sbit XPT2046_DCLK=P3^6;
   7          sbit XPT2046_DOUT=P3^7;
   8          
   9          /**
  10           * @brief       XPT2046读取AD值
  11           * @param       Command 命令字，范围：头文件内定义的宏，结尾的数字表示转换的位数
  12           * @retval      AD转换后的数字量，范围：8位：0~255，12位：0~4095
  13           */
  14          unsigned int  XPT2046_ReadAD(unsigned char Command)
  15          {
  16   1              unsigned int Data=0;    
  17   1              unsigned char i;
  18   1              XPT2046_DCLK=0;
  19   1              XPT2046_CS=0;   
  20   1              for(i=0;i<8;i++)                //发送命令字
  21   1              {
  22   2                      XPT2046_DIN=Command & (0x80>>i);
  23   2                      XPT2046_DCLK=1;
  24   2                      XPT2046_DCLK=0;
  25   2              }
  26   1              for(i=0;i<16;i++)               //接收16位数据
  27   1              {
  28   2                      XPT2046_DCLK=1;
  29   2                      XPT2046_DCLK=0;         
  30   2                      if(XPT2046_DOUT)
  31   2                      {
  32   3                              Data|= (0x8000>>i);
  33   3                      }               
  34   2              }
  35   1              XPT2046_CS=1;           
  36   1              return Data>>8;
  37   1      }
