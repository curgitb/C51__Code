   3          /**
   4           * @brief   定时器0初始化，计时周期为1ms
   5           * @param   无
   6           * @retval  无
   7           */
   8           
   9          void Timer1Init(void)           //1000微秒@11.0592MHz
  10          {
  11   1              TMOD &= 0xF0;           //设置定时器模式
  12   1              TMOD |= 0x01;           //设置定时器模式
  13   1              TL0 = 0x66;             //设置定时初值
  14   1              TH0 = 0xFC;             //设置定时初值
  15   1              TF0 = 0;                //清除TF0标志
  16   1              TR0 = 1;                //定时器0开始计时
  17   1              
  18   1              EA=1;           //设置总体开中断
  19   1              ET0=1;                  //设置允许定时器0中断
  20   1              PT0=0;                  //设置定时器0的中断优先级
  21   1      }
