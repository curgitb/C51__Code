 115           * @param       无
C51 COMPILER V9.54   DS1302                                                                02/22/2026 16:29:16 PAGE 3   

 116           * @retval      无
 117           */
 118          void DS1302_ReadTime(void)
 119          {
 120   1              unsigned char Temp=0;
 121   1              
 122   1              Temp=DS1302_ReadByte(DS1302_Year);      ////将DS1302中存储的BCD码时间转化为十进制时间读出
 123   1              DS1302_Time[0]=Temp/16*10+Temp%16;                              
 124   1              Temp=DS1302_ReadByte(DS1302_Month);
 125   1              DS1302_Time[1]=Temp/16*10+Temp%16;                              
 126   1              Temp=DS1302_ReadByte(DS1302_Date);
 127   1              DS1302_Time[2]=Temp/16*10+Temp%16;                      
 128   1              Temp=DS1302_ReadByte(DS1302_Hour);
 129   1              DS1302_Time[3]=Temp/16*10+Temp%16;                      
 130   1              Temp=DS1302_ReadByte(DS1302_Minute);
 131   1              DS1302_Time[4]=Temp/16*10+Temp%16;                      
 132   1              Temp=DS1302_ReadByte(DS1302_Second);
 133   1              DS1302_Time[5]=Temp/16*10+Temp%16;                              
 134   1              Temp=DS1302_ReadByte(DS1302_Day);               
 135   1              DS1302_Time[6]=Temp/16*10+Temp%16;                      
 136   1      }


