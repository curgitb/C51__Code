   8          //寄存器写入地址/指令定义
   9          #define DS1302_Second   0x80
  10          #define DS1302_Minute   0x82
  11          #define DS1302_Hour     0x84
  12          #define DS1302_Date     0x86
  13          #define DS1302_Month    0x88
  14          #define DS1302_Day              0x8A
  15          #define DS1302_Year     0x8C
  16          #define DS1302_WP               0x8E
  17          
  18          //时间数组，索引0~6分别为年、月、日、时、分、秒、星期
  19          char DS1302_Time[]={26,02,21,14,28,03,06};
  20          
  21          /**
  22           * @brief               DS1302时钟芯片初始化
  23           * @param               无
  24           * @retval              无
  25           */
  26          void DS1302_Init(void)
  27          {
  28   1              DS1302_CE=0;
  29   1              DS1302_SCLK=0;
  30   1      }
  31          
  32          /**
  33           * @brief       向DS1302时钟芯片写入单个字节数据，在哪里/写入/什么
  34           * @param       Command 指令/地址，指明向哪里写入
  35           * @param       Data    数据， 指明写入的数据
  36           * @retval      无
  37           */
  38          void DS1302_WriteByte(unsigned char Command,Data)
  39          {
  40   1              
  41   1              unsigned char i=0;
  42   1              DS1302_CE=1;            //给CE使能，才能完成写入操作
  43   1              
  44   1              for(i=0;i<8;i++)        //8个上升沿，完成指令的传输
  45   1              {
  46   2      
  47   2                      DS1302_IO=Command & (0x01<<i);
  48   2                      DS1302_SCLK=1;          
  49   2                      DS1302_SCLK=0;
  50   2                      
  51   2              }
  52   1              for(i=0;i<8;i++)        //8个上升沿，完成数据的写入
  53   1              {
  54   2                      DS1302_IO=Data & (0x01<<i);
C51 COMPILER V9.54   DS1302                                                                02/22/2026 16:29:16 PAGE 2   

  55   2                      DS1302_SCLK=1;                  
  56   2                      DS1302_SCLK=0;
  57   2              }
  58   1              
  59   1              DS1302_CE=0;
  60   1      }
  61          
  62          /**
  63           * @brief       从DS1302时钟芯片读取单个字节数据，从哪里/读出/什么
  64           * @param       Command 指令/地址，指明从哪里读出
  65           * @retval      Data    数据，返回读出的数据
  66           */
  67          unsigned char DS1302_ReadByte(unsigned char Command)
  68          {
  69   1              unsigned char i=0;
  70   1              unsigned char Data=0;
  71   1              Command|=0x01;          //切换到读的指令/地址
  72   1              DS1302_CE=1;            //给CE使能，才能完成读出操作
  73   1              
  74   1              for(i=0;i<8;i++)        //8个上升沿，完成指令的传输
  75   1              {
  76   2              
  77   2                      DS1302_IO=Command & (0x01<<i);
  78   2                      DS1302_SCLK=0;          
  79   2                      DS1302_SCLK=1;
  80   2                      
  81   2              }
  82   1              for(i=0;i<8;i++)        //8个下降沿，完成数据的读取
  83   1              {
  84   2                      DS1302_SCLK=1;          
  85   2                      DS1302_SCLK=0;          
  86   2                      if(DS1302_IO){Data|=(0x01<<i);}
  87   2      
  88   2              }
  89   1              DS1302_CE=0;    //清零使能位
  90   1              DS1302_IO=0;    //读取后将IO设置为0，否则读出的数据会出错
  91   1              
  92   1              return Data;
  93   1      }
