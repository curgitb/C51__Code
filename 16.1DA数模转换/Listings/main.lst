   1          #include <REGX52.H>
   2          #include "Delay.h"
   3          #include "Timer0.h"
   4          
   5          //引脚定义                          数模转换，通过输出PWM波来实现数字信号到模拟信号的转变
   6          sbit DA=P2^1;
   7          
   8          unsigned char Count,Compare;
   9          unsigned char KeyNum,Speed;
  10          
  11          void main()
  12          {
  13   1              Timer0Init();                   //定时器0初始化
  14   1              while(1)
  15   1              {       
  16   2                      for(Compare=0;Compare<100;Compare++)            //调整比较值来改变PWM占空比
  17   2                      {
  18   3                              Delay(10);
  19   3                      }
  20   2                      for(Compare=100;Compare>0;Compare--)            //调整比较值来改变PWM占空比
  21   2                      {
  22   3                              Delay(10);
  23   3                      }               
  24   2              }
  25   1      }
  26          
  27          void Timer0_Routine() interrupt 1
  28          {
  29   1              TL0 = 0xA4;             //设置定时初值    设置计数时间为100us
  30   1              TH0 = 0xFF;             //设置定时初值
  31   1              Count++;
  32   1              Count%=100;             //计数从0-100循环
  33   1              if(Count<Compare)       //判断计数值和比较值，以此来进行PWM调波进而控制电机转速
  34   1              {
  35   2                      DA=0;   //LED点亮
  36   2              }
  37   1              else
  38   1              {
  39   2                      DA=1;   //LED熄灭
  40   2              }       
  41   1      }


